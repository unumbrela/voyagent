# ══════════════ 必填 ══════════════

# DeepSeek API（8 个 agent 全部走 DeepSeek，https://platform.deepseek.com）
DEEPSEEK_API_KEY=sk-...
# 可选，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Supabase（Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only：service role key（绕过 RLS，绝不能暴露给浏览器）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ══════════════ 可选 ══════════════

# Tavily 搜索（activities/food/accommodation/transport 联网核实真实数据用）
# 免费档每月 1000 次：https://app.tavily.com —— 不填则相关 agent 不联网、靠模型知识作答
TAVILY_API_KEY=

# ── 长期记忆的语义向量（OpenAI 兼容 /embeddings 接口）──
# 不填则用内置哈希向量兜底（可跑通全部功能，只是召回精度低一些）
# EMBED_API_BASE=https://api.openai.com/v1
# EMBED_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small

# ── 高德地图 JS API（首页 3D 实景演示地图）──
# 不填则首页演示地图自动降级为 Leaflet 2D（高德中文栅格瓦片，仍可交互）。
# 申请（免费）：https://console.amap.com/dev/key/app → 创建应用 → 添加 Key →
#   服务平台选「Web 端(JS API)」→ 同时拿到 Key 和安全密钥 securityJsCode，两个都要填。
#   本地调试：域名白名单加 localhost（或留空不限制）。
# NEXT_PUBLIC_AMAP_KEY=你的Key
# NEXT_PUBLIC_AMAP_SECURITY=你的安全密钥securityJsCode

# Claude API（可选；默认全部走 DeepSeek，保留 provider 抽象以便切回）
# ANTHROPIC_API_KEY=
